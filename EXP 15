#include <stdio.h>

int main() {
    int users, files, i, j;
    char fname[20];

    printf("Enter number of users: ");
    scanf("%d",&users);

    for(i=1;i<=users;i++) {
        printf("\nUser %d\n",i);
        printf("Enter number of files: ");
        scanf("%d",&files);

        for(j=1;j<=files;j++) {
            printf("Enter file name: ");
            scanf("%s",fname);
            printf("Stored %s in User %d directory\n",fname,i);
        }
    }

    return 0;
}
