#include <stdio.h>

int main() {
    int n, bt[10], wt[10], tat[10], done[10]={0};
    int time = 0, count = 0, i, idx;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    printf("Enter Burst Time:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &bt[i]);

    while(count < n) {
        idx = -1;

        // Find shortest job among not completed
        for(i = 0; i < n; i++) {
            if(done[i] == 0 && (idx == -1 || bt[i] < bt[idx])) {
                idx = i;
            }
        }

        wt[idx] = time;
        time += bt[idx];
        tat[idx] = wt[idx] + bt[idx];

        done[idx] = 1;
        count++;
    }

    printf("\nBT\tWT\tTAT\n");
    for(i = 0; i < n; i++)
        printf("%d\t%d\t%d\n", bt[i], wt[i], tat[i]);

    return 0;
}
