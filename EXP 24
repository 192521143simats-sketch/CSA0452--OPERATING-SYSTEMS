#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>

int main() {
    int fd;
    char data[100];

    fd = open("sample.txt", O_CREAT | O_RDWR, 0777);

    write(fd, "Hello World", 11);

    lseek(fd, 0, SEEK_SET);

    read(fd, data, 11);
    data[11] = '\0';

    printf("File Content: %s\n", data);

    close(fd);

    return 0;
}
